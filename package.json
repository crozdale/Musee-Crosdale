{
  "name": "facinations",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "facinations:build": "npx hardhat compile && node scripts/verify-events.js && node scripts/generate-subgraph.js && cd subgraph && npx graph codegen && npx graph build",
    "facinations:deploy": "npm run facinations:build && cd subgraph && npx graph deploy facinations -l v0.0.1",
    "facinations:fix": "node scripts/facinations-fix.js",
    "facinations:redeploy": "node scripts/redeploy.js"
  },
  "dependencies": {
    "@apollo/client": "^3.11.8",
    "@tanstack/react-query": "^5.90.21",
    "ethers": "^6.10.0",
    "graphql": "^16.12.0",
    "i18next": "^25.7.3",
    "i18next-http-backend": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "rxjs": "^7.8.2",
    "viem": "^2.43.3",
    "wagmi": "^3.1.3"
  },
   "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.3"
  }

}